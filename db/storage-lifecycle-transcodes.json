{
  "rules": [
    {
      "enabled": true,
      "name": "delete-transcode-outputs-after-35-days",
      "type": "Lifecycle",
      "definition": {
        "filters": {
          "blobTypes": ["blockBlob"],
          "prefixMatch": ["outputs/accounts/"]
        },
        "actions": {
          "baseBlob": {
            "delete": {
              "daysAfterModificationGreaterThan": 35
            }
          }
        }
      }
    }
  ]
}
